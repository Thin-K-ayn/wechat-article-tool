# Copy this file to `.env` and fill in the values you actually use.
# The current workflow uses the WeChat API to push drafts, then publishes
# manually from the WeChat mobile/backend interface.

# Compatible LLM endpoint for article generation.
# OpenAI users can usually keep the default base URL.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-5.4-mini

# WeChat Official Account API credentials.
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# Default article metadata.
WECHAT_DEFAULT_AUTHOR=
WECHAT_DEFAULT_CONTENT_SOURCE_URL=
WECHAT_DEFAULT_MODE=api
WECHAT_DEFAULT_PUBLISH=false

# Optional defaults for generated articles.
ARTICLE_DEFAULT_AUDIENCE=AI practitioners and curious readers
ARTICLE_DEFAULT_STYLE=clear, concise, newsletter-like
